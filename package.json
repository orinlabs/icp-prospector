{
  "name": "flash",
  "private": true,
  "version": "0.0.1",
  "description": "Flash prospecting API + Render Workflows",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "workflow:start": "node dist/workflows/entry.js",
    "cron:sweep": "node dist/workflows/scripts/triggerSweep.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.0",
    "@renderinc/sdk": "^0.5.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.0",
    "hono": "^4.11.0",
    "pg": "^8.16.0",
    "resend": "^6.12.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.15.0",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
